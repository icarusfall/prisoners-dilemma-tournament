# @pdt/frontend env vars.
#
# Copy this file to `.env.local` (gitignored) and uncomment any vars
# you want to override. Anything not set here falls back to the default
# wired into `src/api.ts`.

# Backend base URL. Defaults to the Railway production deploy.
# Point this at http://localhost:3000 when running the backend locally.
# VITE_BACKEND_URL=http://localhost:3000
