# Copy to .env and fill in. .env is gitignored.

# Postgres connection string. On Railway, this is provided automatically
# by the Postgres addon as DATABASE_URL. For local dev, point at the
# Railway-hosted DB or a local Postgres instance.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Anthropic API key. Used by Phase 4+ (NL bot compiler) and Phase 5+
# (MCP server's optional Claude integration). Not required for Phase 1.
ANTHROPIC_API_KEY=
